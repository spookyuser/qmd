{
  "name": "planet-capture",
  "version": "0.1.0",
  "description": "Index and search your browser history with hybrid BM25 + vector search + LLM reranking",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "planet-capture": "bin/planet-capture"
  },
  "files": [
    "bin/",
    "dist/",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && printf '#!/usr/bin/env node\n' | cat - dist/cli/planet-capture.js > dist/cli/planet-capture.tmp && mv dist/cli/planet-capture.tmp dist/cli/planet-capture.js && chmod +x dist/cli/planet-capture.js",
    "test": "vitest run --reporter=verbose test/",
    "dev": "bun src/cli/planet-capture.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spookyuser/planet-capture.git"
  },
  "homepage": "https://github.com/spookyuser/planet-capture#readme",
  "bugs": {
    "url": "https://github.com/spookyuser/planet-capture/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "12.8.0",
    "linkedom": "^0.18.9",
    "node-llama-cpp": "3.18.1",
    "sqlite-vec": "0.1.9",
    "zod": "4.2.1"
  },
  "optionalDependencies": {
    "sqlite-vec-darwin-arm64": "0.1.9",
    "sqlite-vec-darwin-x64": "0.1.9",
    "sqlite-vec-linux-arm64": "0.1.9",
    "sqlite-vec-linux-x64": "0.1.9",
    "sqlite-vec-windows-x64": "0.1.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "tsx": "4.21.0",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "node-llama-cpp"
    ]
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "browser-history",
    "search",
    "fts",
    "full-text-search",
    "vector",
    "semantic-search",
    "sqlite",
    "bm25",
    "embeddings",
    "rag",
    "mcp",
    "reranking",
    "bookmarks",
    "local-ai",
    "llm",
    "readability"
  ],
  "license": "MIT"
}
